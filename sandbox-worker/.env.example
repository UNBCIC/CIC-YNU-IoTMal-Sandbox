# -------------------------------------------------------
# sandbox-worker configuration
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# --- Server ---

# Port the worker API server listens on
PORT=8011

# Base URL prefix for all API routes
APP_BASE_URL="/api/v1/sandbox-worker"

# Host interface to bind to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Unique name for this worker instance (used to identify it in the manager)
APP_NAME=sandbox-worker-1

# Max number of concurrent connections (leave unset for no limit)
# APP_LIMIT_CONCURRENCY=

# TCP backlog size for the server
APP_BACKLOG=2048

# Keep-alive timeout in seconds
APP_TIMEOUT_KEEP_ALIVE=5

# --- Manager ---

# Full base URL of the sandbox-manager API
SANDBOX_MANAGER_URI=http://sandbox-manager:8011/api/v1/sandbox-manager

# --- Network ---

# Set to "false" to block the QEMU VM from accessing the internet and other
# containers. The VM retains access to this worker only (for binary download
# and log uploads). Useful when live C2/DNS observation is not required.
# Default: true (internet access enabled)
ALLOW_VM_INTERNET=true

# --- Analysis ---

# How long (seconds) to let the malware run inside the VM before stopping capture
ANALYSIS_DURATION=30

# How long (seconds) to wait after killing strace/sar before shutting down the VM.
# This allows the virtual filesystem to flush captured files to disk before poweroff.
POST_ANALYSIS_WAIT=30

# --- Paths ---

# Directory where per-task analysis output is written
DATA_DIR=./data/

# Path (inside the task output dir) where the QEMU console log is written
QEMU_LOG_PATH=/qemu.log
