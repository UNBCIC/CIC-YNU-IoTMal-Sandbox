# -------------------------------------------------------
# IoT-CIC-Sandbox — root environment file
# Copy this file to .env and fill in the values.
# This file is used by the top-level docker-compose.yml.
# -------------------------------------------------------

# --- MongoDB credentials (shared by manager and mongo service) ---
MONGO_USERNAME=
MONGO_PASSWORD=

# --- Manager ---

# Host port the manager API is exposed on
MANAGER_PORT=8011

# --- Workers ---

# Seconds to let the malware run inside the VM before stopping monitors
ANALYSIS_DURATION=30

# Seconds to wait after stopping monitors before shutting the VM down
# (allows the guest OS to flush captured files to the virtual disk)
POST_ANALYSIS_WAIT=30

# Set to "false" to block VM internet access. The VM retains access to its
# worker only. Useful when live C2/DNS observation is not required.
# Default: true
ALLOW_VM_INTERNET=true
