# -------------------------------------------------------
# sandbox-manager configuration
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# --- Server ---

# Port the manager API listens on
PORT=8011

# Base URL prefix for all API routes
APP_BASE_URL="/api/v1/sandbox-manager"

# Host interface to bind to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Unique name for this manager instance
APP_NAME=sandbox-manager

# Max number of concurrent connections (leave unset for no limit)
# APP_LIMIT_CONCURRENCY=

# TCP backlog size
APP_BACKLOG=2048

# Keep-alive timeout in seconds
APP_TIMEOUT_KEEP_ALIVE=5

# --- MongoDB ---

# MongoDB host and port
MONGO_HOST=localhost:27017

# MongoDB credentials (required)
MONGO_USERNAME=
MONGO_PASSWORD=

# MongoDB database name
MONGO_DB=sandbox

# --- Paths ---

# Directory containing malware samples to analyse.
# When running in Docker, mount this path as a volume (see docker-compose.yml).
MALWARE_DIRECTORY=/malware

# Directory where completed analysis results (zips from workers) are saved
OUTPUT_DIR=./output/

# Directory where individually submitted malware files are saved
UPLOAD_DIR=./uploads/
